<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="libRangeMap" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/RangeMap" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option external_deps="../libLog/libLog.so;../libLog/liblog.h;" />
				<Option type="3" />
				<Option compiler="gcc" />
				<Option createDefFile="1" />
				<Option createStaticLib="1" />
				<Compiler>
					<Add option="-g" />
					<Add directory="../libLog" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="../libLog" />
				</ResourceCompiler>
				<Linker>
					<Add library="../libLog/libLog.so" />
					<Add directory="../libLog" />
				</Linker>
				<ExtraCommands>
					<Add after="mkdir -p ../../Builds/libRangeMap" />
					<Add after="cp ./librangemap.h ../../Builds/libRangeMap" />
					<Add after="git add ." />
					<Add after='git commit -m &quot;Codeblocks post build commit&quot;' />
				</ExtraCommands>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/RangeMap" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="3" />
				<Option compiler="gcc" />
				<Option createDefFile="1" />
				<Option createStaticLib="1" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
			<Add option="-fexceptions" />
		</Compiler>
		<Unit filename="librangemap.h" />
		<Extensions>
			<code_completion />
			<debugger />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
